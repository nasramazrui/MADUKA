{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user profile",
      "type": "object",
      "properties": {
        "firebaseUid": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["CUSTOMER", "VENDOR", "DRIVER", "ADMIN"] },
        "profilePhoto": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firebaseUid", "name", "role"]
    },
    "Vendor": {
      "title": "Vendor",
      "description": "Vendor business profile",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "businessName": { "type": "string" },
        "businessType": { "type": "string" },
        "address": { "type": "string" },
        "isApproved": { "type": "boolean" }
      },
      "required": ["userId", "businessName", "businessType"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/vendors/{vendorId}": {
      "schema": "Vendor",
      "description": "Vendor profile documents"
    }
  }
}
